{
  "name": "mcp-slim-guard",
  "version": "0.1.0",
  "mcpName": "io.github.lennney/mcp-slim-guard",
  "description": "MCP proxy for schema compression, tool access control, SSRF protection, injection detection, rate limiting and audit logging",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-slim-guard": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "proxy",
    "ssrf",
    "mcp-compression",
    "schema-compression",
    "token-optimization",
    "context-window",
    "mcp-proxy",
    "tool-filtering",
    "claude-code",
    "cursor",
    "codex",
    "ai-security",
    "llm"
  ],
  "homepage": "https://github.com/lennney/mcp-slim-guard",
  "bugs": {
    "url": "https://github.com/lennney/mcp-slim-guard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lennney/mcp-slim-guard.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.{json,md,yml,yaml}'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '*.{json,md,yml,yaml}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run build && npm run check",
    "bench": "node scripts/benchmark/bench.mjs",
    "bench:tokens": "node scripts/benchmark/tokens.mjs",
    "bench:schema": "node scripts/benchmark/schema.mjs",
    "bench:accuracy": "node scripts/benchmark/accuracy.mjs",
    "bench:latency": "node scripts/benchmark/latency.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.8",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.6",
    "tiktoken": "^1.0.22",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.0.0"
  }
}
