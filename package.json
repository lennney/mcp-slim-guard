{
  "name": "micro-mcp",
  "version": "0.4.0",
  "description": "轻量 MCP 代理 — 工具压缩瘦身 (-86%) + SSRF 防护 + 白名单 + 审计 + 限速 + 注入检测",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "micro-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "proxy",
    "ssrf",
    "micro-mcp",
    "ai-security",
    "llm"
  ],
  "homepage": "https://github.com/lennney/micro-mcp",
  "bugs": {
    "url": "https://github.com/lennney/micro-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lennney/micro-mcp.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "bench": "node scripts/benchmark/bench.mjs",
    "bench:tokens": "node scripts/benchmark/tokens.mjs",
    "bench:schema": "node scripts/benchmark/schema.mjs",
    "bench:accuracy": "node scripts/benchmark/accuracy.mjs",
    "bench:latency": "node scripts/benchmark/latency.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.8",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.0.0",
    "tiktoken": "^1.0.22",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
